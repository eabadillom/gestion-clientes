	<parameter name="imagen" class="java.lang.String"/>
	<parameter name="Folio" class="java.lang.String"/>
	<parameter name="esHorarioEspecial" class="java.lang.Boolean"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
	i.*,
	ip.*,
	p.PLANTA_DS,
	p.planta_abrev,
	p.nb_calle,
	p.nu_exterior,
	p.nb_cp,
	ah.asentamiento_ds ,
	ta.tipoasntmnto_ds,
	c.ciudad_ds,
	m.municipio_ds,
	e.estado_desc,
	p2.PRODUCTO_DS,
	p2.NUMERO_PROD,
	p3.pais_desc,
	udm.UNIDAD_DE_MANEJO_DS,
	c2.nb_nombre,
	c2.nb_apellido_1,
	c2.nb_apellido_2 
FROM ingreso i 
INNER JOIN ingreso_producto ip ON i.id_ingreso = ip.id_ingreso 
INNER JOIN planta p ON ip.id_planta = p.PLANTA_CVE 
LEFT JOIN asentamiento_humano ah ON p.id_pais = ah.pais_cve 
	AND p.id_estado = ah.estado_cve 
	AND p.id_municipio = ah.municipio_cve 
	AND p.id_ciudad = ah.ciudad_cve 
	AND p.id_asentamiento = ah.asentamiento_cve 
	AND p.tp_asentamiento = ah.tipoasntmnto_cve
LEFT JOIN tipo_asentamiento ta ON ah.tipoasntmnto_cve = ta.tipoasntmnto_cve 
LEFT JOIN ciudades c ON p.id_pais = c.pais_cve  
	AND p.id_estado = c.estado_cve 
	AND p.id_municipio = c.municipio_cve 
	AND p.id_ciudad = c.ciudad_cve
LEFT JOIN municipios m ON p.id_pais = m.pais_cve 
	AND p.id_estado = m.estado_cve 
	AND p.id_municipio = m.municipio_cve
LEFT JOIN estados e ON p.id_pais = e.pais_cve 
	AND p.id_estado = e.estado_cve
LEFT JOIN paises p3 ON p.id_pais = p3.pais_cve
INNER JOIN producto p2 ON ip.id_producto = p2.PRODUCTO_CVE 
INNER JOIN unidad_de_manejo udm ON ip.id_unidad_medida = udm.UNIDAD_DE_MANEJO_CVE  
INNER JOIN contacto c2 ON i.id_contacto = c2.id_contacto
WHERE i.folio = $P{Folio}]]>
	</queryString>
