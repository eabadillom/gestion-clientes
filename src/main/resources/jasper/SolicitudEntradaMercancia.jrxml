	<subDataset name="Dataset1" uuid="6eb07bf8-ff7b-4e85-80fe-784f2086e7e9">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL-Gestion-Azure.jrdax"/>
		<parameter name="folio" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT ingS.*,
	s.SERVICIO_DS,
	udm.UNIDAD_DE_MANEJO_DS 
FROM ingreso i
INNER JOIN ingreso_servicio ingS ON ingS.id_ingreso = i.id_ingreso  
INNER JOIN servicio s ON ingS.id_servicio = s.SERVICIO_CVE 
INNER JOIN unidad_de_manejo udm ON ingS.id_unidad = udm.UNIDAD_DE_MANEJO_CVE 
WHERE i.folio = $P{folio}]]>
		</queryString>
