	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL-Gestion-Azure.jrdax"/>
	<parameter name="idCliente" class="java.lang.Integer"/>
	<parameter name="fechaInicio" class="java.util.Date"/>
	<parameter name="fechaFin" class="java.util.Date"/>
	<parameter name="imagen" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  	cdd.folio_cliente,
  	cdd.fecha_ingreso,
  	cte.numero_cte,
  	cte.cte_nombre,
  	dp.dtp_codigo,
  	prd.producto_ds,
	dp.dtp_sap,
  	dp.dtp_lote,
  	dp.dtp_po,
  	dp.dtp_caducidad,
  	dp.dtp_tarimas,
  	dp.cantidad_u_manejo,
  	udm.unidad_de_manejo_ds,
  	dp.cantidad_u_medida,
  	plt.planta_cve,
  	plt.planta_abrev AS planta,
  	cam.camara_cve,
  	cam.camara_abrev AS camara
  FROM constancia_de_deposito cdd
    INNER JOIN partida p ON cdd.folio = p.folio
    INNER JOIN cliente cte ON cte.cte_cve = cdd.cte_cve
    INNER JOIN detalle_partida dp ON dp.partida_cve = p.partida_cve
    INNER JOIN unidad_de_manejo udm ON udm.unidad_de_manejo_cve = dp.u_medida_cve
    INNER JOIN unidad_de_producto udp ON udp.unidad_de_producto_cve = p.unidad_de_producto_cve
    INNER JOIN producto prd ON prd.producto_cve = udp.producto_cve
    INNER JOIN camara cam ON cam.camara_cve = p.camara_cve
    INNER JOIN planta plt ON cam.planta_cve = plt.planta_cve
  WHERE dp.det_anterior IS NULL
    AND cdd.fecha_ingreso >= $P{fechaInicio}
    AND cdd.fecha_ingreso <= $P{fechaFin}
    AND cdd.cte_cve = $P{idCliente}
  ORDER BY
    cte.cte_nombre ASC,
    cte.numero_cte ASC,
    prd.producto_ds ASC,
    cdd.fecha_ingreso ASC]]>
	</queryString>
