			<image>
				<reportElement x="0" y="0" width="170" height="62" uuid="2724158f-4062-4add-8439-7b4b150a2081">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<imageExpression><![CDATA[$P{imagen}]]></imageExpression>
			</image>
			<staticText>
				<reportElement mode="Opaque" x="0" y="62" width="48" height="13" forecolor="#FFFFFF" backcolor="#2196F3" uuid="14944891-68f9-48c2-bcf5-3ac3aee0cdd5">
