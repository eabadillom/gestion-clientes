	<queryString language="SQL">
		<![CDATA[SELECT numero , nom_serie  ,nombre_cliente,fecha,subtotal,iva,total,status_factura.nombre FROM factura 
INNER JOIN status_factura ON factura.status = status_factura.id 
WHERE cliente = $P{idCliente}
AND fecha 
BETWEEN $P{fecha_ini} AND $P{fecha_fin}]]>
	</queryString>
